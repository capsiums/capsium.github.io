{
  "$id": "https://www.capsium.org/schemas/authentication.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "authentication": {
      "type": "object",
      "properties": {
        "basicAuth": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "passwdFile": {
              "type": "string",
              "minLength": 1
            },
            "realm": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "enabled",
            "passwdFile"
          ]
        },
        "oauth2": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "provider": {
              "type": "string",
              "minLength": 1
            },
            "clientId": {
              "type": "string",
              "minLength": 1
            },
            "authorizationUrl": {
              "type": "string",
              "format": "uri"
            },
            "tokenUrl": {
              "type": "string",
              "format": "uri"
            },
            "userinfoUrl": {
              "type": "string",
              "format": "uri"
            },
            "redirectPath": {
              "type": "string",
              "minLength": 1
            },
            "scopes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "enabled",
            "clientId",
            "authorizationUrl",
            "tokenUrl",
            "redirectPath"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "authentication"
  ]
}
