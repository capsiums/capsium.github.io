{
  "$id": "https://www.capsium.org/schemas/manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "resources": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "visibility": {
            "type": "string",
            "enum": [
              "exported",
              "private"
            ]
          },
          "version": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "type"
        ]
      }
    }
  },
  "required": [
    "resources"
  ]
}
