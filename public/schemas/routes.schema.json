{
  "$id": "https://www.capsium.org/schemas/routes.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "index": {
      "type": "string",
      "minLength": 1
    },
    "routes": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "resource": {
                "type": "string",
                "minLength": 1
              },
              "headers": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "headersFile": {
                "type": "string",
                "minLength": 1
              },
              "visibility": {
                "type": "string",
                "enum": [
                  "exported",
                  "private"
                ]
              },
              "remap": {
                "type": "string",
                "minLength": 1
              },
              "responseRewrite": {
                "type": "object",
                "properties": {
                  "body": {
                    "type": "string"
                  },
                  "headers": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              },
              "responseHeaders": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "requestHeaders": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "path",
              "resource"
            ]
          },
          {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^\\/api\\/v1\\/data\\/"
              },
              "dataset": {
                "type": "string",
                "minLength": 1
              },
              "accessControl": {
                "type": "object",
                "properties": {
                  "roles": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "authenticationRequired": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": {}
              }
            },
            "required": [
              "path",
              "dataset"
            ]
          },
          {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "method": {
                "type": "string",
                "minLength": 1
              },
              "handler": {
                "type": "string",
                "minLength": 1
              },
              "visibility": {
                "type": "string",
                "enum": [
                  "exported",
                  "private"
                ]
              },
              "remap": {
                "type": "string",
                "minLength": 1
              },
              "responseRewrite": {
                "type": "object",
                "properties": {
                  "body": {
                    "type": "string"
                  },
                  "headers": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              },
              "responseHeaders": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "requestHeaders": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "path",
              "method",
              "handler"
            ],
            "additionalProperties": {}
          }
        ]
      }
    }
  },
  "required": [
    "routes"
  ]
}
