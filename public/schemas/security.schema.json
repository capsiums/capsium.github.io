{
  "$id": "https://www.capsium.org/schemas/security.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "security": {
      "type": "object",
      "properties": {
        "integrityChecks": {
          "type": "object",
          "properties": {
            "checksumAlgorithm": {
              "type": "string",
              "enum": [
                "SHA-256"
              ]
            },
            "checksums": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          },
          "required": [
            "checksumAlgorithm",
            "checksums"
          ]
        },
        "digitalSignatures": {
          "type": "object",
          "properties": {
            "publicKey": {
              "type": "string",
              "minLength": 1
            },
            "signatureFile": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "publicKey",
            "signatureFile"
          ]
        }
      },
      "required": [
        "integrityChecks"
      ]
    }
  },
  "required": [
    "security"
  ]
}
