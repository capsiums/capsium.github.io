{
  "$id": "https://www.capsium.org/schemas/storage.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "storage": {
      "type": "object",
      "properties": {
        "dataSets": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "string",
                    "minLength": 1
                  },
                  "schemaFile": {
                    "type": "string",
                    "minLength": 1
                  },
                  "schemaType": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "source"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "databaseFile": {
                    "type": "string",
                    "minLength": 1
                  },
                  "table": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "databaseFile",
                  "table"
                ]
              }
            ]
          }
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "writable": {
                "type": "boolean"
              },
              "visibility": {
                "type": "string",
                "enum": [
                  "exported",
                  "private"
                ]
              }
            },
            "required": [
              "path"
            ]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "storage"
  ]
}
