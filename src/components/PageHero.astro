---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<section class="relative overflow-hidden border-b border-ink/10 py-20 lg:py-24 dark:border-white/5">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(55rem_24rem_at_15%_-20%,rgba(34,184,212,0.14),transparent),radial-gradient(40rem_18rem_at_90%_10%,rgba(34,184,212,0.07),transparent)] dark:bg-[radial-gradient(55rem_24rem_at_15%_-20%,rgba(34,184,212,0.16),transparent),radial-gradient(40rem_18rem_at_90%_10%,rgba(79,209,229,0.08),transparent)]"
    aria-hidden="true"
  >
  </div>
  <div class="container-site relative">
    <p class="eyebrow">{eyebrow}</p>
    <h1
      class="mt-4 max-w-3xl font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl dark:text-white"
    >
      {title}
    </h1>
    <p class="section-lead">{lead}</p>
  </div>
</section>
