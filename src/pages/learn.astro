---
import Base from '../layouts/Base.astro';
import CommandBlock from '../components/CommandBlock.astro';

const metadataExample = `{
  "name": "my-site",
  "version": "0.1.0",
  "description": "My first Capsium package"
}`;

const inspectCommands = [
  { command: 'capsium package info my-site.cap', note: 'Overview: path, routes, and manifest' },
  { command: 'capsium package manifest my-site.cap', note: 'Full file inventory' },
  { command: 'capsium package routes my-site.cap', note: 'URL routing table' },
  { command: 'capsium package metadata my-site.cap', note: 'Package metadata' },
  { command: 'capsium package storage my-site.cap', note: 'Dataset definitions' },
];
---

<Base
  title="Learn"
  description="Learn to use Capsium: prepare a package directory, pack it with capsium package pack, inspect it, and serve it with capsium reactor serve."
>
  <section class="bg-deep py-16 text-cream lg:py-20">
    <div class="container-site">
      <p class="eyebrow text-aqua">Learn</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">
        Your first Capsium package
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-cream/70">
        A hands-on walkthrough of the Capsium CLI — from a plain directory to a
        packed, served .cap file.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container-site max-w-3xl space-y-16">
      <!-- Step 1 -->
      <div>
        <p class="eyebrow">Step 1</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-deep dark:text-cream">
          Prepare a package directory
        </h2>
        <p class="mt-3 leading-relaxed text-ink/75 dark:text-cream/75">
          A Capsium package starts as an ordinary directory. Put your static files
          in <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-white/10 dark:text-sun">content/</code>,
          your datasets in <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-white/10 dark:text-sun">data/</code>,
          and describe the package in a hand-written
          <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-white/10 dark:text-sun">metadata.json</code>:
        </p>
        <div class="code-block mt-4">
          <pre>my-site/
├── content/
│   └── index.html
├── data/
│   └── animals.yaml
└── metadata.json</pre>
        </div>
        <div class="code-block mt-4">
          <pre>{metadataExample}</pre>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-ink/60 dark:text-cream/60">
          You don't write the other configuration files by hand:
          <code class="font-mono">manifest.json</code>, <code class="font-mono">routes.json</code>,
          <code class="font-mono">storage.json</code>, and <code class="font-mono">security.json</code>
          are generated automatically when you pack.
        </p>
      </div>

      <!-- Step 2 -->
      <div>
        <p class="eyebrow">Step 2</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-deep dark:text-cream">
          Pack the directory
        </h2>
        <p class="mt-3 leading-relaxed text-ink/75 dark:text-cream/75">
          Turn the directory into a portable <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-white/10 dark:text-sun">.cap</code> file:
        </p>
        <div class="mt-4">
          <CommandBlock command="capsium package pack -f path/to/package-dir" />
        </div>
        <p class="mt-3 text-sm leading-relaxed text-ink/60 dark:text-cream/60">
          The packager generates the manifest, routes, storage, and security
          configurations — including SHA-256 checksums for every file — and writes
          the compressed package next to your directory.
        </p>
      </div>

      <!-- Step 3 -->
      <div>
        <p class="eyebrow">Step 3</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-deep dark:text-cream">
          Inspect the package
        </h2>
        <p class="mt-3 leading-relaxed text-ink/75 dark:text-cream/75">
          The CLI reads packages in both directory and packed
          <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-white/10 dark:text-sun">.cap</code> form:
        </p>
        <div class="mt-4 space-y-3">
          {
            inspectCommands.map((item) => (
              <div>
                <CommandBlock command={item.command} />
                <p class="mt-1.5 pl-1 text-xs text-ink/60 dark:text-cream/60">{item.note}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Step 4 -->
      <div>
        <p class="eyebrow">Step 4</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-deep dark:text-cream">
          Serve it with a reactor
        </h2>
        <p class="mt-3 leading-relaxed text-ink/75 dark:text-cream/75">
          Start the built-in Ruby reactor on your package:
        </p>
        <div class="mt-4">
          <CommandBlock command="capsium reactor serve my-site.cap" />
        </div>
        <p class="mt-3 text-sm leading-relaxed text-ink/60 dark:text-cream/60">
          The reactor verifies the package checksums, mounts its routes, and serves
          your content and data over HTTP. Pass
          <code class="font-mono">--port</code> to listen on a different port.
        </p>
      </div>

      <!-- Deploy -->
      <div class="card">
        <h2 class="font-display text-xl font-semibold text-deep dark:text-cream">
          Deploying packages
        </h2>
        <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/75">
          Deploying Capsium packages is straightforward: the same
          <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-white/10 dark:text-sun">.cap</code>
          file you tested locally drops onto any reactor — nginx/OpenResty in
          production, or the browser extension for server-free delivery. Integrate
          the pack step into your existing CI/CD pipeline for automated deployment.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/ecosystem" class="btn-secondary">Explore the reactors</a>
          <a href="/specifications" class="btn-secondary">Read the specifications</a>
        </div>
      </div>
    </div>
  </section>
</Base>
