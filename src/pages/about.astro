---
import Base from '../layouts/Base.astro';
import { repos, repoUrl } from '../data/ecosystem';

const colors = [
  { name: 'Teal', hex: '#0F6B83', role: 'Primary brand color', token: 'primary' },
  { name: 'Deep Teal', hex: '#12404F', role: 'Headings & dark surfaces', token: 'deep' },
  { name: 'Aqua', hex: '#479AA2', role: 'Secondary accents', token: 'aqua' },
  { name: 'Pepper Red', hex: '#A1323A', role: 'Accent — the bell pepper', token: 'pepper' },
  { name: 'Sand', hex: '#D5B579', role: 'Warm highlights', token: 'sand' },
  { name: 'Cream', hex: '#EEEBE3', role: 'Page background', token: 'cream' },
  { name: 'Sun Yellow', hex: '#DAB956', role: 'Sunny accents', token: 'sun' },
];

const useCases = [
  {
    title: 'Static website deployment',
    description: 'Pack a whole site into one .cap file and serve it from any reactor.',
    icon: 'M2 12h20 M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z M12 2a15.3 15.3 0 0 0 0 20 15.3 15.3 0 0 0 0-20 M2 12a10 10 0 1 0 20 0 10 10 0 0 0-20 0',
  },
  {
    title: 'Microservices route mounting',
    description: 'Mount package routes into a larger application, consistently across reactors.',
    icon: 'M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14Z',
  },
  {
    title: 'Data migration',
    description: 'Move content and datasets between systems as self-describing packages.',
    icon: 'M8 3 4 7l4 4 M4 7h16 M16 21l4-4-4-4 M20 17H4',
  },
  {
    title: 'Secure interchange',
    description: 'Exchange content with SHA-256-verified integrity and optional signatures.',
    icon: 'M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z M9 12l2 2 4-4',
  },
  {
    title: 'Version control & updates',
    description: 'Ship explicit versions and dependencies; upgrade without drift.',
    icon: 'M6 3v12 M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z M15 6H9 M18 9v3a3 3 0 0 1-3 3h-3',
  },
];
---

<Base
  title="About"
  description="About Capsium: the name, the logo, the colors, and the Ribose open-source project making content management and deployment easy, secure, and efficient."
>
  <section class="bg-deep py-16 text-cream lg:py-20">
    <div class="container-site">
      <p class="eyebrow text-aqua">About</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">
        About Capsium
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-cream/70">
        Capsium is a project developed by Ribose to provide a common architecture
        for portable, secure information interchange and unified management.
      </p>
    </div>
  </section>

  <!-- The Name & Logo -->
  <section class="py-16 lg:py-20">
    <div class="container-site">
      <p class="eyebrow">The Name &amp; Logo</p>
      <h2 class="section-title mt-3">A capsule with a little kick</h2>
      <div class="mt-8 grid items-center gap-10 lg:grid-cols-2">
        <div class="space-y-5 leading-relaxed text-ink/80 dark:text-cream/80">
          <p>
            <strong class="text-deep dark:text-cream">Capsium</strong> blends two
            words: <em>capsule</em> — the portable, self-contained package at the
            heart of the project — and <em>Capsicum</em>, the bell-pepper genus.
            A capsule you can carry anywhere, with a pepper inside.
          </p>
          <p>
            The logo makes the idea literal: a translucent capsule containing a
            tropical beach diorama — sun, surf, palm trees — with a single red bell
            pepper resting on the sand. The capsule is the package; the beach is
            your content, sealed, portable, and intact wherever it lands.
          </p>
          <p>
            On light pages the capsule's glassy highlights stand out against the
            cream background; on dark pages it glows against deep teal, the beach
            inside lit like a tiny terrarium.
          </p>
        </div>
        <div class="card flex items-center justify-center bg-gradient-to-br from-white to-cream p-10 dark:from-white/10 dark:to-white/5">
          <img
            src="/images/capsium-logo.png"
            alt="The Capsium logo: a translucent capsule containing a tropical beach diorama — sun, ocean, palm trees — with a red bell pepper on the sand"
            width="800"
            height="800"
            class="w-full max-w-xs drop-shadow-[0_20px_40px_rgba(18,64,79,0.25)]"
          />
        </div>
      </div>

      <!-- The Colors -->
      <h3 class="mt-16 font-display text-2xl font-semibold text-deep dark:text-cream">
        The Colors
      </h3>
      <p class="mt-3 max-w-2xl leading-relaxed text-ink/80 dark:text-cream/80">
        The palette is drawn straight from the logo — deep teal water, sandy beach,
        tropical sun, and one very red bell pepper.
      </p>
      <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {
          colors.map((color) => (
            <div class="overflow-hidden rounded-2xl border border-deep/10 dark:border-white/10">
              <div class="h-20" style={`background-color: ${color.hex}`} />
              <div class="bg-white p-4 dark:bg-white/5">
                <p class="font-semibold text-deep dark:text-cream">{color.name}</p>
                <p class="font-mono text-xs text-ink/60 dark:text-cream/60">{color.hex}</p>
                <p class="mt-1 text-xs text-ink/60 dark:text-cream/60">{color.role}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Origin + Mission -->
  <section class="bg-white py-16 lg:py-20 dark:bg-black/20">
    <div class="container-site grid gap-10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Origin Story</p>
        <h2 class="mt-3 font-display text-2xl font-semibold text-deep dark:text-cream">
          Built at Ribose
        </h2>
        <p class="mt-4 leading-relaxed text-ink/80 dark:text-cream/80">
          Capsium was created at Ribose to solve a recurring problem: content
          deployment should be portable and secure by default, not an exercise in
          rebuilding the same pipeline for every platform. Capsium packages make
          content a self-contained, verifiable artifact — pack it once and serve it
          anywhere.
        </p>
      </div>
      <div>
        <p class="eyebrow">Mission Statement</p>
        <h2 class="mt-3 font-display text-2xl font-semibold text-deep dark:text-cream">
          Our mission
        </h2>
        <p class="mt-4 leading-relaxed text-ink/80 dark:text-cream/80">
          Our mission is to make content management and deployment easy, secure, and
          efficient for developers, packagers, deployers, users, and organizations.
        </p>
      </div>
    </div>
  </section>

  <!-- Ecosystem -->
  <section class="py-16 lg:py-20">
    <div class="container-site">
      <p class="eyebrow">The Ecosystem</p>
      <h2 class="section-title mt-3">The project family</h2>
      <div class="mt-10 overflow-x-auto rounded-2xl border border-deep/10 dark:border-white/10">
        <table class="w-full min-w-[36rem] text-left text-sm">
          <thead>
            <tr class="bg-deep text-cream">
              <th scope="col" class="px-5 py-3.5 font-semibold">Project</th>
              <th scope="col" class="px-5 py-3.5 font-semibold">Description</th>
              <th scope="col" class="px-5 py-3.5 font-semibold">Category</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-deep/10 bg-white dark:divide-white/10 dark:bg-white/5">
            {
              repos.map((repo) => (
                <tr class="transition-colors hover:bg-primary/5 dark:hover:bg-white/10">
                  <td class="px-5 py-3.5">
                    <a
                      href={repoUrl(repo.name)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-mono font-semibold text-primary hover:underline dark:text-aqua"
                    >
                      {repo.name}
                    </a>
                  </td>
                  <td class="px-5 py-3.5 text-ink/75 dark:text-cream/75">{repo.description}</td>
                  <td class="px-5 py-3.5">
                    <span class="rounded-full bg-primary/10 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-primary dark:bg-aqua/15 dark:text-aqua">
                      {repo.category}
                    </span>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="bg-white py-16 lg:py-20 dark:bg-black/20">
    <div class="container-site">
      <p class="eyebrow">Use Cases</p>
      <h2 class="section-title mt-3">Where Capsium fits</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          useCases.map((useCase) => (
            <div class="card">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary dark:bg-aqua/15 dark:text-aqua">
                <svg class="h-5.5 w-5.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={useCase.icon} />
                </svg>
              </div>
              <h3 class="mt-4 font-display text-lg font-semibold text-deep dark:text-cream">
                {useCase.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/70 dark:text-cream/70">
                {useCase.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Open Source -->
  <section class="py-16 lg:py-20">
    <div class="container-site grid gap-10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Open Source</p>
        <h2 class="mt-3 font-display text-2xl font-semibold text-deep dark:text-cream">
          Open by default
        </h2>
        <p class="mt-4 leading-relaxed text-ink/80 dark:text-cream/80">
          Capsium is an open-source project. Every repository is developed in the
          open under the
          <a href="https://github.com/capsiums" target="_blank" rel="noopener noreferrer" class="font-semibold text-primary hover:underline dark:text-aqua">capsiums</a>
          organization on GitHub and released under the MIT license. Contributions
          are welcome — fork a repository and open a pull request.
        </p>
      </div>
      <div>
        <p class="eyebrow">Get Started</p>
        <h2 class="mt-3 font-display text-2xl font-semibold text-deep dark:text-cream">
          Ready to dive in?
        </h2>
        <ul class="mt-4 space-y-2.5 leading-relaxed text-ink/80 dark:text-cream/80">
          <li>
            <strong class="text-deep dark:text-cream">1.</strong>
            <a href="/install" class="font-semibold text-primary hover:underline dark:text-aqua">Install the CLI</a> and verify your setup
          </li>
          <li>
            <strong class="text-deep dark:text-cream">2.</strong>
            <a href="/learn" class="font-semibold text-primary hover:underline dark:text-aqua">Follow the walkthrough</a> to pack your first package
          </li>
          <li>
            <strong class="text-deep dark:text-cream">3.</strong>
            <a href="/specifications" class="font-semibold text-primary hover:underline dark:text-aqua">Read the specifications</a> behind the format
          </li>
          <li>
            <strong class="text-deep dark:text-cream">4.</strong>
            <a href="https://github.com/capsiums" target="_blank" rel="noopener noreferrer" class="font-semibold text-primary hover:underline dark:text-aqua">Star the repos</a> and join the project on GitHub
          </li>
        </ul>
      </div>
    </div>
  </section>
</Base>
