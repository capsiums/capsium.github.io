---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { repos, repoUrl } from '../data/ecosystem';

const colors = [
  { name: 'Midnight', hex: '#0A1C24', role: 'Dark page background', token: 'abyss' },
  { name: 'Surface Teal', hex: '#12404F', role: 'Cards & elevated surfaces', token: 'surface' },
  { name: 'Electric Teal', hex: '#22B8D4', role: 'Primary actions', token: 'primary' },
  { name: 'Glow Cyan', hex: '#4FD1E5', role: 'Glow & highlight accents', token: 'glow' },
  { name: 'Pepper Red', hex: '#E85D64', role: 'Accent — the bell pepper', token: 'pepper' },
  { name: 'Sun Yellow', hex: '#DAB956', role: 'Sunny accents', token: 'sun' },
  { name: 'Sand', hex: '#D5B579', role: 'Warm highlights', token: 'sand' },
  { name: 'Cream', hex: '#EEEBE3', role: 'Light page background', token: 'cream' },
];

const useCases = [
  {
    title: 'Static website deployment',
    description: 'Pack a whole site into one .cap file and serve it from any reactor.',
    icon: 'M2 12h20 M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z M12 2a15.3 15.3 0 0 0 0 20 15.3 15.3 0 0 0 0-20 M2 12a10 10 0 1 0 20 0 10 10 0 0 0-20 0',
  },
  {
    title: 'Microservices route mounting',
    description: 'Mount package routes into a larger application, consistently across reactors.',
    icon: 'M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14Z',
  },
  {
    title: 'Data migration',
    description: 'Move content and datasets between systems as self-describing packages.',
    icon: 'M8 3 4 7l4 4 M4 7h16 M16 21l4-4-4-4 M20 17H4',
  },
  {
    title: 'Secure interchange',
    description: 'Exchange content with SHA-256-verified integrity and optional signatures.',
    icon: 'M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z M9 12l2 2 4-4',
  },
  {
    title: 'Version control & updates',
    description: 'Ship explicit versions and dependencies; upgrade without drift.',
    icon: 'M6 3v12 M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z M15 6H9 M18 9v3a3 3 0 0 1-3 3h-3',
  },
];
---

<Base
  title="About"
  description="About Capsium: the name (capsule + -ium + Capsicum), the logo, the colors, and the Ribose open-source project behind the elemental unit of web deployment."
>
  <PageHero
    eyebrow="About"
    title="About Capsium"
    lead="Capsium is a project developed by Ribose to provide a common architecture for portable, secure information interchange and unified management."
  />

  <!-- The Name & Logo -->
  <section class="py-16 lg:py-20">
    <div class="container-site">
      <p class="eyebrow" data-reveal>The Name &amp; Logo</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">
        An element of the deployment table
      </h2>
      <div class="mt-8 grid items-center gap-10 lg:grid-cols-2">
        <div class="space-y-5 leading-relaxed text-ink/80 dark:text-cream/75">
          <p>
            <strong class="text-ink dark:text-white">Capsium</strong> is a word
            built from three parts, and each one carries a piece of the
            architecture.
          </p>
          <ul class="space-y-4">
            <li class="flex gap-3.5">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
              <span>
                <strong class="font-display text-ink dark:text-white">caps- — the capsule.</strong>{' '}
                A Capsium package is one whole capsule containing an entire
                website or webservice: content, data, routes, and metadata enclosed
                whole — self-contained, tamper-evident by design.
              </span>
            </li>
            <li class="flex gap-3.5">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
              <span>
                <strong class="font-display text-ink dark:text-white">-ium — the element suffix.</strong>{' '}
                Like helium or titanium, a Capsium package is an indivisible,
                fundamental unit — a wholeness unto itself. You deploy it whole or
                not at all; it is the elemental unit of web deployment.
              </span>
            </li>
            <li class="flex gap-3.5">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-pepper"></span>
              <span>
                <strong class="font-display text-ink dark:text-white">Capsicum — the pepper genus.</strong>{' '}
                A nod to the red bell pepper resting inside the logo's capsule —
                a little kick inside every package.
              </span>
            </li>
          </ul>
          <p>
            The logo makes the idea literal: a translucent capsule containing a
            tropical beach diorama — sun, surf, palm trees — with a single red
            bell pepper on the sand. The capsule is the package; the beach is your
            content — enclosed, portable, provably intact wherever it lands.
          </p>
        </div>
        <div class="card flex items-center justify-center bg-gradient-to-br from-white to-cream p-10 dark:from-white/[0.06] dark:to-transparent">
          <img
            src="/images/capsium-logo.png"
            alt="The Capsium logo: a translucent capsule containing a tropical beach diorama — sun, ocean, palm trees — with a red bell pepper on the sand"
            width="640"
            height="640"
            class="w-full max-w-xs drop-shadow-[0_20px_40px_rgba(18,64,79,0.35)]"
          />
        </div>
      </div>

      <!-- The Colors -->
      <h3 class="mt-16 font-display text-2xl font-semibold tracking-tight text-ink dark:text-white" data-reveal>
        The Colors
      </h3>
      <p class="mt-3 max-w-2xl leading-relaxed text-ink/80 dark:text-cream/75" data-reveal>
        The palette is drawn straight from the logo — deep teal water, sandy
        beach, tropical sun, and one very red bell pepper — brightened for
        screens into the "midnight capsule" theme.
      </p>
      <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {
          colors.map((color) => (
            <div class="overflow-hidden rounded-2xl border border-ink/10 dark:border-white/10">
              <div class="h-20" style={`background-color: ${color.hex}`} />
              <div class="bg-white p-4 dark:bg-white/[0.04]">
                <p class="font-semibold text-ink dark:text-white">{color.name}</p>
                <p class="font-mono text-xs text-ink/60 dark:text-cream/55">{color.hex}</p>
                <p class="mt-1 text-xs text-ink/60 dark:text-cream/55">{color.role}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Origin + Mission -->
  <section class="border-y border-ink/10 bg-white/60 py-16 lg:py-20 dark:border-white/5 dark:bg-white/[0.02]">
    <div class="container-site grid gap-10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Origin Story</p>
        <h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink dark:text-white">
          Built at Ribose
        </h2>
        <p class="mt-4 leading-relaxed text-ink/80 dark:text-cream/75">
          Capsium was created at Ribose to solve a recurring problem: content
          deployment should be portable and secure by default, not an exercise in
          rebuilding the same pipeline for every platform. Capsium packages make
          content a self-contained, verifiable artifact — pack it once and serve it
          anywhere.
        </p>
      </div>
      <div>
        <p class="eyebrow">Mission Statement</p>
        <h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink dark:text-white">
          Our mission
        </h2>
        <p class="mt-4 leading-relaxed text-ink/80 dark:text-cream/75">
          Our mission is to make content management and deployment easy, secure, and
          efficient for developers, packagers, deployers, users, and organizations.
        </p>
      </div>
    </div>
  </section>

  <!-- Ecosystem -->
  <section class="py-16 lg:py-20">
    <div class="container-site">
      <p class="eyebrow" data-reveal>The Ecosystem</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">The project family</h2>
      <div class="mt-10 overflow-x-auto rounded-2xl border border-ink/10 dark:border-white/10" data-reveal>
        <table class="w-full min-w-[36rem] text-left text-sm">
          <thead>
            <tr class="bg-night text-cream">
              <th scope="col" class="px-5 py-3.5 font-display font-semibold">Project</th>
              <th scope="col" class="px-5 py-3.5 font-display font-semibold">Description</th>
              <th scope="col" class="px-5 py-3.5 font-display font-semibold">Category</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink/10 bg-white dark:divide-white/10 dark:bg-white/[0.03]">
            {
              repos.map((repo) => (
                <tr class="transition-colors hover:bg-primary/5 dark:hover:bg-white/5">
                  <td class="px-5 py-3.5">
                    <a
                      href={repoUrl(repo.name)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-mono font-semibold text-primary hover:underline dark:text-glow"
                    >
                      {repo.name}
                    </a>
                  </td>
                  <td class="px-5 py-3.5 text-ink/75 dark:text-cream/70">{repo.description}</td>
                  <td class="px-5 py-3.5">
                    <span class="chip">{repo.category}</span>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-y border-ink/10 bg-white/60 py-16 lg:py-20 dark:border-white/5 dark:bg-white/[0.02]">
    <div class="container-site">
      <p class="eyebrow" data-reveal>Use Cases</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">Where Capsium fits</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          useCases.map((useCase, i) => (
            <div class="card" data-reveal style={`--reveal-delay: ${i * 60}ms`}>
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary dark:bg-glow/10 dark:text-glow">
                <svg class="h-5.5 w-5.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={useCase.icon} />
                </svg>
              </div>
              <h3 class="mt-4 font-display text-lg font-semibold tracking-tight text-ink dark:text-white">
                {useCase.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/70 dark:text-cream/65">
                {useCase.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Open Source -->
  <section class="py-16 lg:py-20">
    <div class="container-site grid gap-10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Open Source</p>
        <h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink dark:text-white">
          Open by default
        </h2>
        <p class="mt-4 leading-relaxed text-ink/80 dark:text-cream/75">
          Capsium is an open-source project. Every repository is developed in
          the open under the{' '}
          <a href="https://github.com/capsiums" target="_blank" rel="noopener noreferrer" class="font-semibold text-primary hover:underline dark:text-glow">capsiums</a>{' '}
          organization on GitHub and released under the MIT license. Contributions
          are welcome — fork a repository and open a pull request.
        </p>
      </div>
      <div>
        <p class="eyebrow">Get Started</p>
        <h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-ink dark:text-white">
          Ready to dive in?
        </h2>
        <ul class="mt-4 space-y-2.5 leading-relaxed text-ink/80 dark:text-cream/75">
          <li>
            <strong class="text-ink dark:text-white">1.</strong>
            <a href="/install" class="font-semibold text-primary hover:underline dark:text-glow">Install the CLI</a> and verify your setup
          </li>
          <li>
            <strong class="text-ink dark:text-white">2.</strong>
            <a href="/learn" class="font-semibold text-primary hover:underline dark:text-glow">Follow the walkthrough</a> to pack your first package
          </li>
          <li>
            <strong class="text-ink dark:text-white">3.</strong>
            <a href="/specifications" class="font-semibold text-primary hover:underline dark:text-glow">Read the specifications</a> behind the format
          </li>
          <li>
            <strong class="text-ink dark:text-white">4.</strong>
            <a href="https://github.com/capsiums" target="_blank" rel="noopener noreferrer" class="font-semibold text-primary hover:underline dark:text-glow">Star the repos</a> and join the project on GitHub
          </li>
        </ul>
      </div>
    </div>
  </section>
</Base>
