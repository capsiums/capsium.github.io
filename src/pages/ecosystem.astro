---
import Base from '../layouts/Base.astro';
import { repos, repoUrl } from '../data/ecosystem';

const groups = [
  {
    title: 'Packagers',
    note: 'Tools that build, inspect, and convert Capsium packages.',
    filter: (r: (typeof repos)[number]) => r.category === 'Packager',
  },
  {
    title: 'Reactors',
    note: 'Runtimes that verify, mount, and serve Capsium packages.',
    filter: (r: (typeof repos)[number]) => r.category === 'Reactor',
  },
  {
    title: 'Samples & Standards',
    note: 'Example packages and the specification itself.',
    filter: (r: (typeof repos)[number]) => r.category === 'Sample' || r.category === 'Standard',
  },
];
---

<Base
  title="Ecosystem"
  description="The Capsium open-source ecosystem: Ruby and TypeScript packagers, Ruby, nginx/Lua, browser-extension and service-worker reactors, plus samples and the CC 62001 standard."
>
  <section class="bg-deep py-16 text-cream lg:py-20">
    <div class="container-site">
      <p class="eyebrow text-aqua">Ecosystem</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">
        Packagers and reactors
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-cream/70">
        Capsium is a family of open-source projects. Packagers build the portable
        .cap files; reactors serve them on every platform.
      </p>
    </div>
  </section>

  {
    groups.map((group) => (
      <section class="border-b border-deep/10 py-14 last:border-b-0 dark:border-white/10">
        <div class="container-site">
          <h2 class="font-display text-2xl font-semibold text-deep dark:text-cream">
            {group.title}
          </h2>
          <p class="mt-2 text-ink/70 dark:text-cream/70">{group.note}</p>
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {repos.filter(group.filter).map((repo) => (
              <a
                href={repoUrl(repo.name)}
                target="_blank"
                rel="noopener noreferrer"
                class="card group block"
              >
                <div class="flex items-center justify-between gap-3">
                  <h3 class="font-mono text-base font-semibold text-deep group-hover:text-primary dark:text-cream dark:group-hover:text-sun">
                    {repo.name}
                  </h3>
                  <span class="rounded-full bg-primary/10 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-primary dark:bg-aqua/15 dark:text-aqua">
                    {repo.category}
                  </span>
                </div>
                <p class="mt-2 text-sm leading-relaxed text-ink/70 dark:text-cream/70">
                  {repo.description}
                </p>
                <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary dark:text-aqua">
                  View on GitHub
                  <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7M7 7h10v10" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="py-14">
    <div class="container-site text-center">
      <p class="text-ink/70 dark:text-cream/70">
        Everything is developed in the open under the
        <a
          href="https://github.com/capsiums"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-primary hover:underline dark:text-aqua"
        >
          capsiums
        </a>
        organization on GitHub.
      </p>
    </div>
  </section>
</Base>
