---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CapInspector from '../components/CapInspector.vue';
import CapLiveServing from '../components/CapLiveServing.vue';
---

<Base
  title="Playground"
  description="Inspect a Capsium .cap package entirely in your browser — metadata, routes, SHA-256 integrity — then serve it live from a service worker and browse it in a real preview, no server involved."
>
  <PageHero
    eyebrow="Playground"
    title="Open a capsule in your browser"
    lead="Drop any .cap package below. It is unzipped and inspected entirely on your device — nothing is uploaded — using the same contract files every reactor reads. Then serve it live: a service worker answers its routes right here."
  />

  <section class="py-16 lg:py-20">
    <div class="container-site max-w-4xl">
      <CapInspector client:load />

      <div class="mt-10">
        <CapLiveServing client:load />
      </div>
    </div>
  </section>
</Base>
