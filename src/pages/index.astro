---
import Base from '../layouts/Base.astro';
import CommandBlock from '../components/CommandBlock.astro';
import ContractDiagram from '../components/ContractDiagram.vue';

const pillars = [
  {
    title: 'A whole site in one capsule',
    description:
      'Content, data, routes, and metadata sealed in a single .cap file — self-contained, immutable, versionable.',
    icon: 'M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z M3.3 7 12 12l8.7-5 M12 22V12',
  },
  {
    title: 'The contract',
    description:
      'metadata, manifest, routes, storage, security — five JSON files every packager writes and every reactor reads.',
    icon: 'M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z M14 2v4a2 2 0 0 0 2 2h4 M9 13l2 2 4-4',
  },
  {
    title: 'Multilayer capsules',
    description:
      'Packages stack as immutable overlay layers and declare dependencies — compose sites from capsules.',
    icon: 'M12 2 2 7l10 5 10-5-10-5Z M2 17l10 5 10-5 M2 12l10 5 10-5',
  },
  {
    title: 'Deploy anywhere',
    description:
      'The same file activates on Ruby, nginx/OpenResty, a browser extension, or a service worker. No rebuilds.',
    icon: 'M2 12h20 M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z M12 2a15.3 15.3 0 0 0 0 20 15.3 15.3 0 0 0 0-20 M2 12a10 10 0 1 0 20 0 10 10 0 0 0-20 0',
  },
];

const quickstart = [
  { command: 'gem install capsium', note: 'Install the CLI' },
  { command: 'capsium package pack -f my-site/', note: 'Pack a directory into a .cap' },
  { command: 'capsium reactor serve my-site-1.0.0.cap', note: 'Serve it with the Ruby reactor' },
];

const ecosystem = [
  { name: 'capsium', kind: 'Packager', note: 'Ruby gem and CLI' },
  { name: 'capsium-js', kind: 'Packager + Reactor', note: 'TypeScript runtime & service worker' },
  { name: 'capsium-lua', kind: 'Reactor', note: 'nginx / OpenResty' },
  { name: 'capsium-webextension', kind: 'Reactor', note: 'Chrome & Firefox' },
];
---

<Base
  title="The elemental unit of web deployment"
  description="Capsium packs an entire website or webservice into one self-contained, self-verifying capsule — the standardized contract between those who package and those who deploy. Package once. Serve anywhere."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(70rem_36rem_at_75%_-15%,rgba(34,184,212,0.12),transparent),radial-gradient(46rem_26rem_at_5%_115%,rgba(34,184,212,0.06),transparent)] dark:bg-[radial-gradient(70rem_36rem_at_75%_-15%,rgba(34,184,212,0.22),transparent),radial-gradient(46rem_26rem_at_5%_115%,rgba(79,209,229,0.08),transparent)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-site relative grid items-center gap-14 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:py-28">
      <div class="min-w-0">
        <p class="eyebrow" data-reveal>
          Capsium — Common architecture for portable secure information
          interchange and unified management
        </p>
        <h1
          class="mt-6 font-display text-5xl font-semibold leading-[1.05] tracking-tight text-ink sm:text-6xl lg:text-7xl dark:text-white"
          data-reveal
          style="--reveal-delay: 80ms"
        >
          The <span class="text-gradient">elemental unit</span> of web deployment.
        </h1>
        <p
          class="mt-6 max-w-xl text-lg leading-relaxed text-ink/70 sm:text-xl dark:text-cream/70"
          data-reveal
          style="--reveal-delay: 160ms"
        >
          One whole capsule for an entire website or webservice — self-contained,
          self-verifying, immutable. Capsium is the standardized contract between
          those who package and those who deploy. Package once. Serve anywhere.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-4" data-reveal style="--reveal-delay: 240ms">
          <a href="/install" class="btn-primary">Get started</a>
          <a href="/playground" class="btn-secondary">
            Try it in your browser
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14m-6-6 6 6-6 6" />
            </svg>
          </a>
          <a
            href="https://github.com/capsiums"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full px-4 py-3 text-sm font-semibold text-ink/70 transition-colors hover:text-primary dark:text-cream/70 dark:hover:text-glow"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.76 2.69 1.25 3.35.96.1-.75.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
              ></path>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>

      <div class="relative mx-auto w-full min-w-0 max-w-md lg:max-w-none" data-reveal style="--reveal-delay: 200ms">
        <div
          class="absolute -inset-8 rounded-[3rem] bg-primary/20 blur-3xl dark:bg-primary/25"
          aria-hidden="true"
        >
        </div>
        <img
          src="/images/hero-image.jpg"
          alt="Three glowing capsules, each holding a bell pepper diorama, floating above a moonlit coast"
          width="1024"
          height="1024"
          class="relative w-full rounded-[2rem] border border-white/15 shadow-2xl shadow-black/40 ring-1 ring-primary/20"
          loading="eager"
          fetchpriority="high"
        />
        <div
          class="absolute -bottom-5 left-1/2 flex -translate-x-1/2 items-center gap-2 whitespace-nowrap rounded-full border border-white/15 bg-night/85 px-4 py-2 font-mono text-xs text-glow shadow-lg backdrop-blur-md"
          aria-hidden="true"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-glow"></span>
          my-site-1.0.0.cap — SHA-256 verified
        </div>
      </div>
    </div>
  </section>

  <!-- The contract -->
  <section class="border-y border-ink/10 bg-white/60 py-20 lg:py-24 dark:border-white/5 dark:bg-white/[0.02]">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow" data-reveal>The contract</p>
        <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">
          One capsule, understood by every reactor
        </h2>
        <p class="section-lead mx-auto" data-reveal style="--reveal-delay: 120ms">
          A .cap package is the standardized interface between the people who
          package and the people who deploy. Hover or tab through the diagram.
        </p>
      </div>
      <div class="mt-14" data-reveal style="--reveal-delay: 160ms">
        <ContractDiagram client:visible />
      </div>
    </div>
  </section>

  <!-- USP pillars -->
  <section class="py-20 lg:py-24">
    <div class="container-site">
      <p class="eyebrow" data-reveal>Why Capsium</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">
        Wholeness, sealed in
      </h2>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          pillars.map((pillar, i) => (
            <div class="card group" data-reveal style={`--reveal-delay: ${i * 70}ms`}>
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary/20 dark:bg-glow/10 dark:text-glow dark:group-hover:bg-glow/20">
                <svg class="h-5.5 w-5.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={pillar.icon} />
                </svg>
              </div>
              <h3 class="mt-4 font-display text-lg font-semibold tracking-tight text-ink dark:text-white">
                {pillar.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/70 dark:text-cream/65">
                {pillar.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Quickstart -->
  <section class="border-y border-ink/10 bg-white/60 py-20 lg:py-24 dark:border-white/5 dark:bg-white/[0.02]">
    <div class="container-site">
      <div class="grid items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="min-w-0">
          <p class="eyebrow" data-reveal>Works out of the box</p>
          <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">
            Three commands to a served capsule
          </h2>
          <p class="section-lead" data-reveal style="--reveal-delay: 120ms">
            The Capsium CLI packs any directory into a verified .cap and serves it
            with the built-in Ruby reactor — no configuration, no runtime
            dependencies.
          </p>
          <div class="mt-8" data-reveal style="--reveal-delay: 180ms">
            <a href="/learn" class="btn-secondary">Follow the full walkthrough</a>
          </div>
        </div>
        <div class="min-w-0 rounded-2xl border border-white/10 bg-night p-4 shadow-2xl shadow-primary/10 sm:p-5" data-reveal style="--reveal-delay: 140ms">
          <div class="flex items-center gap-1.5 px-2 pb-3" aria-hidden="true">
            <span class="h-2.5 w-2.5 rounded-full bg-pepper/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-sun/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-primary/80"></span>
          </div>
          <div class="space-y-3">
            {
              quickstart.map((item) => (
                <div>
                  <CommandBlock command={item.command} />
                  <p class="mt-1.5 pl-1 text-xs text-cream/45">{item.note}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ecosystem teaser -->
  <section class="py-20 lg:py-24">
    <div class="container-site">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="eyebrow" data-reveal>Ecosystem</p>
          <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">Packagers and reactors</h2>
          <p class="section-lead" data-reveal style="--reveal-delay: 120ms">
            An open-source family of tools that build Capsium packages and serve
            them on any platform.
          </p>
        </div>
        <a href="/ecosystem" class="btn-secondary" data-reveal>Full ecosystem</a>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          ecosystem.map((repo, i) => (
            <a
              href={`https://github.com/capsiums/${repo.name}`}
              target="_blank"
              rel="noopener noreferrer"
              class="card group block"
              data-reveal
              style={`--reveal-delay: ${i * 70}ms`}
            >
              <span class="chip">{repo.kind}</span>
              <h3 class="mt-3 font-mono text-base font-semibold text-ink group-hover:text-primary dark:text-white dark:group-hover:text-glow">
                {repo.name}
              </h3>
              <p class="mt-1 text-sm text-ink/70 dark:text-cream/65">{repo.note}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden border-t border-white/5 bg-night py-20 text-cream lg:py-24">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(50rem_22rem_at_50%_130%,rgba(34,184,212,0.35),transparent)]"
      aria-hidden="true"
    >
    </div>
    <div class="container-site relative text-center">
      <h2 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl" data-reveal>
        Ready to pack your first capsule?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-cream/65" data-reveal style="--reveal-delay: 80ms">
        Install the Ruby gem, pack a directory, and serve it locally in under a minute.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4" data-reveal style="--reveal-delay: 160ms">
        <a href="/install" class="btn-primary">Install Capsium</a>
        <a href="/playground" class="btn-outline">Open the playground</a>
      </div>
    </div>
  </section>
</Base>
