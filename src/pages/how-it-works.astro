---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import PackageTree from '../components/PackageTree.vue';

const principles = [
  {
    title: 'Ease of use',
    description: 'Creating, packing, and serving a package takes a handful of CLI commands.',
  },
  {
    title: 'Cross-platform deployment',
    description: 'The same .cap file runs on every reactor, from nginx to the browser.',
  },
  {
    title: 'Static nature',
    description: 'Packages are plain files — no databases, no server-side runtime required.',
  },
  {
    title: 'Size efficiency',
    description: 'ZIP compression and a lean structure keep packages small and fast to transfer.',
  },
  {
    title: 'Integrity',
    description: 'SHA-256 checksums for every file let reactors detect any tampering.',
  },
  {
    title: 'Self-containment',
    description: 'Content, data, routes, and metadata travel together in one artifact.',
  },
  {
    title: 'Versioning',
    description: 'Every package declares its version, making upgrades explicit and auditable.',
  },
  {
    title: 'Dependencies',
    description: 'Packages declare what they depend on, so reactors can resolve stacks of content.',
  },
  {
    title: 'Immutable layered filesystem',
    description: 'Packages mount as read-only layers; changes come from new versions, never edits.',
  },
  {
    title: 'Deployment-API compatibility',
    description: 'A stable contract between packages and reactors across the whole ecosystem.',
  },
];

const concepts = [
  {
    term: 'Capsium package',
    definition:
      'A single portable file — extension .cap, MIME type application/vnd.capsium.package — that bundles content, data, and configuration into a checksummed ZIP archive.',
  },
  {
    term: 'Package filesystem',
    definition:
      'Inside the package, content and data live in an immutable, layered filesystem. Layers stack predictably, and nothing is ever mutated in place.',
  },
  {
    term: 'Reactor',
    definition:
      'Any runtime that reads a Capsium package and serves it: the Ruby reactor, the nginx/OpenResty Lua reactor, the browser extension, or the service worker.',
  },
  {
    term: 'Activation',
    definition:
      'The moment a reactor loads a package: it verifies checksums, mounts the layered filesystem, and starts answering the routes declared in routes.json.',
  },
];
---

<Base
  title="How it works"
  description="How Capsium works: a portable .cap capsule with an immutable layered filesystem is the contract; reactors verify its checksums, mount its routes, and serve it anywhere."
>
  <PageHero
    eyebrow="How it works"
    title="One package, many reactors"
    lead="Capsium splits content management into two clean halves: a portable package format, and reactors that serve it. Here is how the pieces fit together."
  />

  <!-- Core concepts -->
  <section class="py-16 lg:py-20">
    <div class="container-site">
      <p class="eyebrow" data-reveal>Concepts</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">Four ideas, one architecture</h2>
      <dl class="mt-10 grid gap-6 md:grid-cols-2">
        {
          concepts.map((concept, i) => (
            <div class="card" data-reveal style={`--reveal-delay: ${i * 60}ms`}>
              <dt class="font-display text-lg font-semibold tracking-tight text-primary dark:text-glow">
                {concept.term}
              </dt>
              <dd class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
                {concept.definition}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Package structure -->
  <section class="border-y border-ink/10 bg-white/60 py-16 lg:py-20 dark:border-white/5 dark:bg-white/[0.02]">
    <div class="container-site">
      <p class="eyebrow" data-reveal>Inside a package</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">Anatomy of a .cap file</h2>
      <p class="section-lead" data-reveal style="--reveal-delay: 120ms">
        A Capsium package is a ZIP archive with a rigorous structure. You hand-write{' '}
        <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-glow/10 dark:text-glow">metadata.json</code>{' '}
        and fill <code class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-glow/10 dark:text-glow">content/</code>;{' '}
        the packager generates the rest. Click any entry to explore it.
      </p>
      <div class="mt-10" data-reveal>
        <PackageTree client:visible />
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="py-16 lg:py-20">
    <div class="container-site">
      <p class="eyebrow" data-reveal>Design principles</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">Principles from the standard</h2>
      <p class="section-lead" data-reveal style="--reveal-delay: 120ms">
        The CC 62001 draft standard defines the principles every Capsium package and
        reactor follows.
      </p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          principles.map((principle, i) => (
            <div class="rounded-xl border border-ink/10 bg-white p-5 transition-colors hover:border-primary/30 dark:border-white/10 dark:bg-white/[0.04] dark:hover:border-glow/30" data-reveal style={`--reveal-delay: ${i * 40}ms`}>
              <h3 class="font-display font-semibold tracking-tight text-ink dark:text-white">{principle.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink/70 dark:text-cream/65">
                {principle.description}
              </p>
            </div>
          ))
        }
      </div>
      <div class="mt-12 text-center">
        <a href="/specifications" class="btn-secondary">Read the specifications</a>
      </div>
    </div>
  </section>
</Base>
