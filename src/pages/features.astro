---
import Base from '../layouts/Base.astro';

const audiences = [
  {
    title: 'Developers',
    icon: 'm16 18 6-6-6-6 M8 6l-6 6 6 6',
    benefits: [
      'Structured content management',
      'Robust API for package manipulation',
      'Detailed metadata and routing configurations',
      'Integration with existing CI/CD pipelines',
    ],
  },
  {
    title: 'Packagers',
    icon: 'M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z M3.3 7 12 12l8.7-5 M12 22V12',
    benefits: [
      'Easy packaging and distribution of content',
      'Version control and dependency management',
      'Enhanced security and compliance features',
      'Efficient storage and retrieval of content',
    ],
  },
  {
    title: 'Deployers',
    icon: 'M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09Z M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Z M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0 M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5',
    benefits: [
      'Simplified deployment process',
      'Cross-platform compatibility',
      'Cost-effective and scalable deployment',
      'Comprehensive monitoring and logging',
    ],
  },
  {
    title: 'Users',
    icon: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z M22 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75',
    benefits: [
      'Access to rich and interactive content',
      'Fast and reliable content delivery',
      'Consistent user experience across devices',
      'Secure and private content access',
    ],
  },
  {
    title: 'Organizations',
    icon: 'M3 21h18 M5 21V7l7-4 7 4v14 M9 21v-6h6v6 M9 10h.01 M15 10h.01 M9 14h.01 M15 14h.01',
    benefits: [
      'Improved content governance and compliance',
      'Streamlined content workflows',
      'Better collaboration among teams',
      'Reduced operational costs',
    ],
  },
];
---

<Base
  title="Features"
  description="Capsium benefits for developers, packagers, deployers, users, and organizations — structured content management, portable packages, and secure deployment."
>
  <section class="bg-deep py-16 text-cream lg:py-20">
    <div class="container-site">
      <p class="eyebrow text-aqua">Features</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight sm:text-5xl">
        Something for everyone in the content lifecycle
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-cream/70">
        Capsium offers a wide range of features that cater to different audiences —
        developers, packagers, deployers, users, and organizations.
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="container-site grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        audiences.map((audience) => (
          <div class="card flex flex-col">
            <div class="flex items-center gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary dark:bg-aqua/15 dark:text-aqua">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={audience.icon} />
                </svg>
              </div>
              <h2 class="font-display text-xl font-semibold text-deep dark:text-cream">
                {audience.title}
              </h2>
            </div>
            <ul class="mt-5 flex-1 space-y-3">
              {audience.benefits.map((benefit) => (
                <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink/80 dark:text-cream/80">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-pepper" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  {benefit}
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <!-- CTA card -->
      <div class="card flex flex-col justify-center bg-primary text-white dark:bg-primary">
        <h2 class="font-display text-xl font-semibold">Ready to try it?</h2>
        <p class="mt-2 text-sm leading-relaxed text-white/80">
          Install the Ruby gem and pack your first Capsium package in minutes.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/install" class="btn bg-white text-primary hover:bg-cream">Install</a>
          <a href="/learn" class="btn border border-white/40 text-white hover:border-white">Learn</a>
        </div>
      </div>
    </div>
  </section>
</Base>
