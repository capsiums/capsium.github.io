---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const structure = [
  {
    name: 'Content',
    description: 'Static files like HTML, CSS, and JavaScript — the payload a reactor serves.',
  },
  {
    name: 'Data',
    description: 'Structured data files, such as YAML or JSON, exposed as datasets.',
  },
  {
    name: 'Metadata',
    description: 'Descriptive information about the package: name, version, and dependencies.',
  },
  {
    name: 'Routes',
    description: 'Mapping of URLs to content or data endpoints.',
  },
  {
    name: 'Storage',
    description: 'Definitions for datasets and their sources, formats, and schemas.',
  },
];

const metadataExample = `{
  "name": "my-site",
  "version": "0.1.0",
  "description": "A sample Capsium package",
  "guid": "com.example.my-site",
  "uuid": "3f6b0d2a-9c4e-4b1a-8e7d-2c5f9a1b0e3d",
  "license": "MIT",
  "repository": "https://github.com/example/my-site",
  "dependencies": {
    "com.example.shared-assets": "^1.2.0"
  },
  "readOnly": true
}`;

const inlineCode = 'rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm text-primary dark:bg-glow/10 dark:text-glow';
---

<Base
  title="Specifications"
  description="The Capsium package specification: the contract files (metadata, manifest, routes, storage, security), SHA-256 integrity, the .cap extension, and the application/vnd.capsium.package MIME type."
>
  <PageHero
    eyebrow="Specifications"
    title="The Capsium package format"
    lead="Capsium provides a common architecture for portable, secure information interchange and unified management. These are the core specifications."
  />

  <!-- Package structure -->
  <section class="py-16 lg:py-20">
    <div class="container-site">
      <p class="eyebrow" data-reveal>Structure</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">What a package contains</h2>
      <p class="section-lead" data-reveal style="--reveal-delay: 120ms">A Capsium package typically includes five parts:</p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {
          structure.map((item, i) => (
            <div class="card" data-reveal style={`--reveal-delay: ${i * 50}ms`}>
              <h3 class="font-display text-lg font-semibold tracking-tight text-primary dark:text-glow">
                {item.name}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/70 dark:text-cream/65">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Configuration -->
  <section class="border-y border-ink/10 bg-white/60 py-16 lg:py-20 dark:border-white/5 dark:bg-white/[0.02]">
    <div class="container-site grid items-start gap-10 lg:grid-cols-2">
      <div>
        <p class="eyebrow" data-reveal>Configuration</p>
        <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">Configured with JSON</h2>
        <p class="section-lead" data-reveal style="--reveal-delay: 120ms">
          Capsium packages are configured using JSON files covering metadata, routes,
          storage, and security. You author{' '}
          <code class={inlineCode}>metadata.json</code>;{' '}
          the packager generates the rest.
        </p>
        <ul class="mt-6 space-y-3">
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink/80 dark:text-cream/75">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
            <span><strong class="text-ink dark:text-white">Identity</strong> — name, version, description, guid, and uuid pin down exactly what the package is.</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink/80 dark:text-cream/75">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
            <span><strong class="text-ink dark:text-white">Provenance</strong> — license and repository record where the package comes from.</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink/80 dark:text-cream/75">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
            <span><strong class="text-ink dark:text-white">Dependencies</strong> — declared with version constraints, resolved by reactors.</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink/80 dark:text-cream/75">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
            <span><strong class="text-ink dark:text-white">readOnly</strong> — marks the package as immutable once packed.</span>
          </li>
        </ul>
      </div>
      <div class="code-block" data-reveal>
        <p class="mb-3 font-display text-xs font-semibold uppercase tracking-wider text-glow">metadata.json</p>
        <pre class="text-[13px]">{metadataExample}</pre>
      </div>
    </div>
  </section>

  <!-- Security + file format -->
  <section class="py-16 lg:py-20">
    <div class="container-site grid gap-6 md:grid-cols-2">
      <div class="card" data-reveal>
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-pepper/15 text-pepper">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z M9 12l2 2 4-4" />
          </svg>
        </div>
        <h2 class="mt-4 font-display text-xl font-semibold tracking-tight text-ink dark:text-white">
          Security
        </h2>
        <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
          Every file in a package is fingerprinted with a SHA-256 checksum recorded
          in <code class={inlineCode}>security.json</code>.
          Packages can additionally carry RSA digital signatures, so reactors can
          verify both integrity and origin before serving anything.
        </p>
      </div>
      <div class="card" data-reveal style="--reveal-delay: 80ms">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary dark:bg-glow/10 dark:text-glow">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
            <path d="M14 2v4a2 2 0 0 0 2 2h4 M10 9H8 M16 13H8 M16 17H8" />
          </svg>
        </div>
        <h2 class="mt-4 font-display text-xl font-semibold tracking-tight text-ink dark:text-white">
          File format
        </h2>
        <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
          A Capsium package is a ZIP archive with the{' '}
          <code class={inlineCode}>.cap</code>{' '}
          extension and the registered MIME type{' '}
          <code class={inlineCode}>application/vnd.capsium.package</code>.
          Any standards-compliant ZIP tool can inspect one.
        </p>
      </div>
    </div>

    <!-- Deployment note -->
    <div class="container-site mt-6">
      <div class="card" data-reveal>
        <h2 class="font-display text-xl font-semibold tracking-tight text-ink dark:text-white">
          Deployment
        </h2>
        <p class="mt-2 max-w-3xl leading-relaxed text-ink/75 dark:text-cream/70">
          Capsium packages are deployed using a Capsium reactor, which reads the
          package configuration and serves the content and data according to the
          defined routes — verify first, then mount.
        </p>
      </div>
    </div>

    <!-- Standard link -->
    <div class="container-site mt-12">
      <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-night p-8 text-cream sm:p-10" data-reveal>
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(36rem_14rem_at_85%_0%,rgba(34,184,212,0.25),transparent)]"
          aria-hidden="true"
        >
        </div>
        <div class="relative flex flex-wrap items-center justify-between gap-6">
          <div class="max-w-xl">
            <h2 class="font-display text-2xl font-semibold tracking-tight">The full standard</h2>
            <p class="mt-2 leading-relaxed text-cream/65">
              These pages summarize the format. The normative text lives in the CC
              62001 draft standard, developed in the open.
            </p>
          </div>
          <a
            href="https://github.com/capsiums/standards"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline"
          >
            capsiums/standards
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
