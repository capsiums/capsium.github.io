---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CommandBlock from '../components/CommandBlock.astro';
---

<Base
  title="Install"
  description="Install Capsium as a Ruby gem — gem install capsium or bundle add capsium — then verify with capsium --version. Docker, nginx, and browser reactors also available."
>
  <PageHero
    eyebrow="Install"
    title="Up and running in a minute"
    lead="Capsium is distributed as a Ruby gem. Install it, verify it, and you are ready to pack and serve your first capsule."
  />

  <section class="py-16 lg:py-20">
    <div class="container-site max-w-3xl space-y-14">
      <!-- Standalone -->
      <div data-reveal>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink dark:text-white">
          Standalone installation
        </h2>
        <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
          Install the Capsium gem directly from RubyGems:
        </p>
        <div class="mt-4">
          <CommandBlock command="gem install capsium" />
        </div>
      </div>

      <!-- Bundler -->
      <div data-reveal>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink dark:text-white">
          Using Bundler
        </h2>
        <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
          Add Capsium to your project's Gemfile:
        </p>
        <div class="mt-4">
          <CommandBlock command="bundle add capsium" />
        </div>
      </div>

      <!-- Verify -->
      <div data-reveal>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink dark:text-white">
          Verify the installation
        </h2>
        <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
          Check that the CLI is on your PATH and see the installed version:
        </p>
        <div class="mt-4">
          <CommandBlock command="capsium --version" />
        </div>
        <p class="mt-3 text-sm text-ink/60 dark:text-cream/55">
          You should see the installed version of Capsium printed to the terminal.
        </p>
      </div>
    </div>
  </section>

  <!-- Other reactors -->
  <section class="border-t border-ink/10 bg-white/60 py-16 lg:py-20 dark:border-white/5 dark:bg-white/[0.02]">
    <div class="container-site">
      <p class="eyebrow" data-reveal>Beyond the CLI</p>
      <h2 class="section-title mt-4" data-reveal style="--reveal-delay: 60ms">Other ways to run Capsium</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <div class="card" data-reveal>
          <h3 class="font-display text-lg font-semibold tracking-tight text-ink dark:text-white">
            nginx / OpenResty reactor
          </h3>
          <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
            Serve Capsium packages at production scale with the Lua reactor for
            nginx and OpenResty — Docker images included.
          </p>
          <a
            href="https://github.com/capsiums/capsium-lua"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline dark:text-glow"
          >
            capsiums/capsium-lua
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10" />
            </svg>
          </a>
        </div>
        <div class="card" data-reveal style="--reveal-delay: 80ms">
          <h3 class="font-display text-lg font-semibold tracking-tight text-ink dark:text-white">
            Browser extension
          </h3>
          <p class="mt-2 leading-relaxed text-ink/75 dark:text-cream/70">
            Open and browse .cap packages directly in Chrome or Firefox — no server
            required at all.
          </p>
          <a
            href="https://github.com/capsiums/capsium-webextension"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline dark:text-glow"
          >
            capsiums/capsium-webextension
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10" />
            </svg>
          </a>
        </div>
      </div>
      <div class="mt-12 text-center">
        <a href="/learn" class="btn-primary">Next: pack your first package</a>
      </div>
    </div>
  </section>
</Base>
